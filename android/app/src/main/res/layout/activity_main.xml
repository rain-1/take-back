<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0F1115">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#E7E9EE"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="webrtc nat-passthrough prototype"
            android:textColor="#8B93A7"
            android:paddingBottom="12dp" />

        <!-- Step 1: nickname -->
        <LinearLayout
            android:id="@+id/nickStep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/enter_nickname"
                android:textColor="#8B93A7" />

            <EditText
                android:id="@+id/nickInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. river"
                android:textColor="#E7E9EE"
                android:textColorHint="#5B6273"
                android:inputType="text"
                android:importantForAutofill="no" />

            <Button
                android:id="@+id/nickBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cont" />
        </LinearLayout>

        <!-- Step 2: lobby -->
        <LinearLayout
            android:id="@+id/lobbyStep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/hostBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/host_call" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/join_with_code"
                android:textColor="#8B93A7"
                android:paddingTop="12dp" />

            <EditText
                android:id="@+id/joinInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="ABCD12"
                android:textColor="#E7E9EE"
                android:textColorHint="#5B6273"
                android:inputType="textCapCharacters"
                android:importantForAutofill="no" />

            <Button
                android:id="@+id/joinBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/join" />
        </LinearLayout>

        <!-- Step 3: call -->
        <LinearLayout
            android:id="@+id/callStep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/call_code"
                    android:textColor="#8B93A7" />

                <TextView
                    android:id="@+id/callCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:textColor="#E7E9EE"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <Button
                    android:id="@+id/copyBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/copy" />
            </LinearLayout>

            <TextView
                android:id="@+id/status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/connecting"
                android:textColor="#8B93A7" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/shareBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/share_screen" />

                <Button
                    android:id="@+id/flipBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/flip_camera" />

                <Button
                    android:id="@+id/leaveBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/leave" />
            </LinearLayout>

            <GridLayout
                android:id="@+id/videoGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
