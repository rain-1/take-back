<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- App theme mapped onto the web palette. Dark, accent-blue, rounded. -->
    <style name="Theme.TakeBack" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/tb_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/tb_accent</item>
        <item name="android:colorBackground">@color/tb_bg</item>
        <item name="colorSurface">@color/tb_panel</item>
        <item name="colorOnSurface">@color/tb_text</item>
        <item name="colorOnBackground">@color/tb_text</item>
        <item name="android:statusBarColor">@color/tb_panel</item>
        <item name="android:windowBackground">@color/tb_bg</item>
        <item name="materialButtonStyle">@style/TbButton</item>
    </style>

    <!-- Accent, rounded buttons like the web's primary button. -->
    <style name="TbButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">10dp</item>
        <item name="backgroundTint">@color/tb_accent</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>
</resources>
